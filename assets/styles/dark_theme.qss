/* Modern Dark Theme for L-Drive Pro */
QWidget {
    background-color: #1e1e1e;
    color: #e0e0e0;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
}

QMainWindow {
    background-color: #121212;
}

QGroupBox {
    border: 1px solid #333333;
    border-radius: 8px;
    margin-top: 15px;
    padding-top: 15px;
    font-weight: bold;
    color: #4a9eff;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 3px 0 3px;
}

QLabel {
    color: #b0b0b0;
}

#StatusLabel {
    font-size: 11pt;
    font-weight: bold;
    color: #ff9800; /* Orange for Disconnected by default */
}

QLineEdit, QComboBox, QPlainTextEdit {
    background-color: #2d2d2d;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    padding: 5px;
    color: #ffffff;
}

QComboBox::drop-down {
    border: 0px;
}

QPushButton {
    background-color: #3d3d3d;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-weight: bold;
    min-height: 20px;
}

QPushButton:hover {
    background-color: #4d4d4d;
}

#MountButton {
    background-color: #2e7d32;
    color: white;
}

#MountButton:hover {
    background-color: #388e3c;
}

#UnmountButton {
    background-color: #c62828;
    color: white;
}

#UnmountButton:hover {
    background-color: #d32f2f;
}

QRadioButton::indicator {
    width: 13px;
    height: 13px;
}

QCheckBox::indicator {
    width: 15px;
    height: 15px;
}

QScrollBar:vertical {
    border: none;
    background: #1e1e1e;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #3d3d3d;
    min-height: 20px;
    border-radius: 5px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
